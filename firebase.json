{
  "hosting": {
    "public": "apps/web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/meetings/*/live", "destination": "/index.html" },
      { "source": "/meetings/*/setup", "destination": "/index.html" },
      { "source": "/meetings/*/summary", "destination": "/index.html" },
      { "source": "/healthz", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/auth", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/auth/**", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/users", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/users/**", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/user", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/user/**", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/meetings", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/meetings/**", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/accounts", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/accounts/**", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/team", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/team/**", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/logs", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/ws/**", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/api/tasks", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/api/tasks/**", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "/calendar/**", "run": { "serviceId": "scoach-api", "region": "us-central1" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" },
          { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  },
  "firestore": {
    "rules": "infra/firebase/firestore.rules",
    "indexes": "infra/firebase/firestore.indexes.json"
  },
  "storage": {
    "rules": "infra/firebase/storage.rules"
  }
}
