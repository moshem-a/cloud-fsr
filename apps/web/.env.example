# Copy to .env.local and fill in. .env.local is git-ignored.
# Get these from Firebase console → Project settings → General → Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=gcp-sales-coach-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gcp-sales-coach-dev

# API base. Defaults to http://localhost:8080 in dev (MSW intercepts most calls).
VITE_API_BASE_URL=http://localhost:8080
